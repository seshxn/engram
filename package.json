{
  "name": "engram",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "engram": "./packages/core/bin/engram.js"
  },
  "description": "Persistent local memory for AI coding agents. Learns from your sessions, remembers across them.",
  "author": "seshanpillay",
  "license": "AGPL-3.0-only",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:claude-code-plugin": "node packages/adapter-claude-code/build.mjs",
    "install:claude-code-plugin": "bash ./scripts/install-claude-plugin.sh",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "test:core": "vitest run --project core",
    "test:claude-code": "vitest run --project claude-code",
    "test:plugin-kit": "vitest run --project plugin-kit"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  }
}
